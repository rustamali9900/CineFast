<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true"
    android:id="@+id/seats"
    >

    <LinearLayout
        android:id="@+id/theater_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="40dp"
        android:paddingBottom="40dp"
        tools:context=".Seats">

        <View
            android:layout_width="300dp"
            android:layout_height="8dp"
            android:layout_marginBottom="50dp"
            android:background="@drawable/screen_curve" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />

            <View android:layout_width="40dp" android:layout_height="35dp" />

            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_occupied_red" android:tag="occupied" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />

            <View android:layout_width="40dp" android:layout_height="35dp" />

            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_occupied_red" android:tag="occupied" />
            <View android:layout_width="35dp" android:layout_height="35dp" android:layout_margin="3dp" android:background="@drawable/seat_bg" android:tag="available" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>